// メモ
// dockerfileだけでは、@fsあたりへのアクセスがうまくいかず、
// docker-composeを介すことで、正常に動作するようになった。

{
	"name": "obsidian-d2-standalone",
	"dockerComposeFile": "compose.yml",
	"service": "app",
	"workspaceFolder": "/workspace",
	"customizations": {
		"vscode": {
			"extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
		}
	},
	"remoteUser": "node"
}
